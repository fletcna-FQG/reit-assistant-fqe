SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=redis://127.0.0.1:6379
PORT=3000
NODE_ENV=development

# --- Supabase Management API (for scripts/configure-brevo-smtp.sh) ---
# Personal access token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Subdomain from SUPABASE_URL (e.g. yzepjzjkbjbmfveihllf)
SUPABASE_PROJECT_REF=

# --- Brevo REST API (share report emails via src/services/emailAdapter.ts) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=reports@fletcherquillestates.com
BREVO_SENDER_NAME="FQ Estates"

# --- Brevo SMTP (Supabase Auth: signup confirm, password reset, invite) ---
# Create an SMTP key at Brevo → Settings → SMTP & API → SMTP (NOT the REST API key)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
BREVO_SMTP_SENDER_EMAIL=reports@fletcherquillestates.com
BREVO_SMTP_SENDER_NAME="FQ Estates"

# Auth email behaviour (after Brevo SMTP is configured in Supabase)
# false = require email confirmation on register (Supabase sends via SMTP)
AUTH_AUTO_CONFIRM_EMAIL=true
AUTH_RESET_REDIRECT_URL=http://localhost:8081/login
AUTH_CONFIRM_REDIRECT_URL=http://localhost:8081/login

# Document sharing integrations
SMS_PROVIDER=ghl
GHL_API_KEY=
GHL_LOCATION_ID=
AA_API_KEY=

# Optional integrations
AA_COMMUNITY_ID=
ATTOM_API_KEY=
ATTOM_BASE_URL=
