# REIT Assistant — Expo web (static export) for Northflank
# Build from repo root: docker build -f Dockerfile.web .

FROM node:20-bookworm-slim AS builder

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ARG EXPO_PUBLIC_USE_LIVE_API=true
ARG EXPO_PUBLIC_API_URL=https://p01--reit-assistant-v2--99vpsnwm46h4.code.run
ARG EXPO_PUBLIC_SUPABASE_URL=
ARG EXPO_PUBLIC_SUPABASE_ANON_KEY=

ENV EXPO_PUBLIC_USE_LIVE_API=$EXPO_PUBLIC_USE_LIVE_API
ENV EXPO_PUBLIC_API_URL=$EXPO_PUBLIC_API_URL
ENV EXPO_PUBLIC_SUPABASE_URL=$EXPO_PUBLIC_SUPABASE_URL
ENV EXPO_PUBLIC_SUPABASE_ANON_KEY=$EXPO_PUBLIC_SUPABASE_ANON_KEY
ENV CI=true

RUN npx expo export --platform web

FROM nginx:1.27-alpine

COPY nginx.web.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
